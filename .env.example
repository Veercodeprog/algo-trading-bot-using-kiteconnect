# =========================================
# Zerodha Kite CLI - .env.example
# =========================================

# Must match what you set in Kite developer console
KITE_LISTEN_ADDR=127.0.0.1:4000
KITE_REDIRECT_URL=http://127.0.0.1:4000/callback

KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# =========================================
# Order Demo Safety
# =========================================
# Must be true to allow real order placement
ORDER_DEMO_ENABLED=false
ORDER_LIVE_ENABLED=false
LIVE_TRADING_ENABLED=false

# =========================================
# Default Order Parameters
# =========================================
ORDER_EXCHANGE=NSE
ORDER_SYMBOL=INFY
ORDER_QTY=1
ORDER_PRODUCT=CNC
ORDER_TAG=rust_demo

# =========================================
# Position Conversion Safety
# =========================================
POSITION_CONVERT_ENABLED=false

# Conversion Defaults
CONVERT_EXCHANGE=NSE
CONVERT_SYMBOL=INFY
CONVERT_QTY=1
CONVERT_POSITION_TYPE=day
CONVERT_OLD_PRODUCT=MIS
CONVERT_NEW_PRODUCT=CNC
CONVERT_TRANSACTION_TYPE=BUY

# =========================================
# WebSocket / Ticker Settings
# =========================================
# Comma-separated instrument tokens
TICKER_TOKENS=738561

# Modes: ltp | quote | full
TICKER_MODE=ltp

# SMA period for websocket strategy
TICKER_SMA_PERIOD=10

# =========================================
# Trading Strategy Settings
# =========================================
TRADE_EXCHANGE=NSE
TRADE_SYMBOL=RELIANCE
TRADE_QTY=1
TRADE_PRODUCT=MIS
TRADE_TAG=sma_ws_demo

# Optional margin check before placing buy orders
CHECK_MARGIN_BEFORE_BUY=true

# =========================================
# Margin Estimation Example
# =========================================
MARGIN_EXCHANGE=NSE
MARGIN_SYMBOL=RELIANCE
MARGIN_QTY=100
MARGIN_PRODUCT=MIS
MARGIN_ORDER_TYPE=LIMIT
MARGIN_PRICE=0
MARGIN_TRIGGER_PRICE=0

# =========================================
# Low Frequency Strategy
# =========================================
LOWFREQ_EXCHANGE=NSE
LOWFREQ_SYMBOL=RELIANCE
LOWFREQ_INTERVAL=day
LOWFREQ_SMA_PERIOD=200
LOWFREQ_LOOKBACK_DAYS=300
LOWFREQ_CHECK_SECONDS=3600

# Optional: Hardcode token instead of lookup
# LOWFREQ_INSTRUMENT_TOKEN=738561

# =========================================
# Advanced Order Examples
# =========================================
ADV_EXCHANGE=NSE
ADV_PRODUCT=MIS
ADV_TAG=advanced_demo

# =========================================
# Cover Order Example
# =========================================
CO_SYMBOL=TATAMOTORS
CO_QTY=10
CO_SL_TRIGGER=0

# =========================================
# After Market Order Example
# =========================================
AMO_SYMBOL=INFY
AMO_QTY=5
AMO_LIMIT_PRICE=0
AMO_PRODUCT=CNC

# =========================================
# Iceberg Order Example
# =========================================
ICE_SYMBOL=ITC
ICE_QTY=100
ICE_LEGS=4
ICE_LIMIT_PRICE=0
ICE_PRODUCT=CNC

# =========================================
# GTT Single Trigger Example
# =========================================
GTT_SINGLE_SYMBOL=TCS
GTT_SINGLE_PRODUCT=CNC
GTT_SINGLE_QTY=5
GTT_SINGLE_TRIGGER=0
GTT_SINGLE_ORDER_PRICE=0

# =========================================
# GTT OCO (Two Leg) Example
# =========================================
GTT_OCO_SYMBOL=HDFCBANK
GTT_OCO_PRODUCT=CNC
GTT_OCO_QTY=5
GTT_OCO_SL_TRIGGER=0
GTT_OCO_TARGET_TRIGGER=0
GTT_OCO_SL_ORDER_PRICE=0
GTT_OCO_TARGET_ORDER_PRICE=0



BACKTEST_EXCHANGE=NSE
BACKTEST_SYMBOL=RELIANCE
BACKTEST_INTERVAL=day
BACKTEST_FROM=2023-01-01
BACKTEST_TO=2025-12-31

BACKTEST_CONTINUOUS=false
BACKTEST_OI=false

BACKTEST_MA_FAST=20
BACKTEST_MA_SLOW=50

BACKTEST_START_CAPITAL=100000
BACKTEST_COMMISSION_PCT=0.02
BACKTEST_SLIPPAGE_PCT=0.01

BACKTEST_OUT_CSV=backtest_sma_trades.csv

